---
import { Image } from 'astro:assets';

import pdfIcon from '../../assets/icons/adobe-pdf.png';
import docsIcon from '../../assets/icons/google-docs.png';
import formsIcon from '../../assets/icons/google-forms.jpg';
import spreadsheetsIcon from '../../assets/icons/google-sheets.png';
import slidesIcon from '../../assets/icons/google-slides.png';
import zipIcon from '../../assets/icons/zip.png';

interface Props {
  href: string;
  type?: 'pdf' | 'forms' | 'docs' | 'slides' | 'zip' | 'spreadsheets';
}

let { href, type } = Astro.props;

if (!type) {
  const lowerHref = href.toLowerCase();
  if (lowerHref.includes('docs.google.com/document')) {
    type = 'docs';
  } else if (lowerHref.includes('docs.google.com/presentation')) {
    type = 'slides';
  } else if (lowerHref.includes('docs.google.com/spreadsheets')) {
    type = 'spreadsheets';
  } else if (lowerHref.includes('docs.google.com/forms')) {
    type = 'forms';
  } else if (lowerHref.endsWith('.pdf') || lowerHref.includes('.pdf?')) {
    type = 'pdf';
  } else if (lowerHref.endsWith('.zip') || lowerHref.includes('.zip?')) {
    type = 'zip';
  }
}

const ICONS = {
  pdf: pdfIcon,
  forms: formsIcon,
  docs: docsIcon,
  slides: slidesIcon,
  zip: zipIcon,
  spreadsheets: spreadsheetsIcon,
};

const icon = type ? ICONS[type] : undefined;
---

<a href={href} class="usa-link display-inline-flex flex-align-center text-no-underline hover:text-underline padding-y-1" target="_blank" rel="noopener noreferrer">
  {icon && <Image src={icon} alt={`${type} icon`} class="width-3 height-4 flex-no-shrink margin-right-2" />}
  <span><slot /></span>
</a>
