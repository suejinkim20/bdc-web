---
import Base from '@layouts/Base.astro';
---

<Base title="Consortium Google Drive">
  <h1>Consortium Google Drive</h1>

  <p>
    Access the shared consortium drive:
    <a
      href="https://drive.google.com/example-consortium-drive"
      class="usa-link"
      target="_blank"
      rel="noopener noreferrer"
    >
      Open Google Drive
    </a>
  </p>

  <h2>Best Practices</h2>

  <div class="usa-alert usa-alert--info">
    <div class="usa-alert__body">
      <p class="usa-alert__text">Best practices content coming soon.</p>
    </div>
  </div>
</Base>
