---
import '../styles/global.scss';
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '@components/layout/SiteHeader.astro';
import favicon from '../assets/favicon.png';

interface Props {
  title: string;
}

const { title } = Astro.props;
const displayTitle = title.includes('BioData Catalyst')
  ? title
  : `${title} | BioData Catalyst Consortium`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <title>{displayTitle}</title>
    <ClientRouter />
  </head>
  <body class="display-flex flex-column" style="min-height: 100vh;">
    <a class="usa-skipnav" href="#main-content">Skip to main content</a>
    <SiteHeader transition:persist />
    <main id="main-content" class="grid-container" style="flex: 1; width: 100%;">
      <slot />
    </main>
    <div class="bg-base-lightest padding-y-4 margin-top-4">
      <div class="grid-container">
        <footer class="usa-footer">
          <p>For general inquiries, contact <a href="mailto:bdc3@renci.org">bdc3@renci.org</a></p>
        </footer>
      </div>
    </div>
  </body>
</html>
